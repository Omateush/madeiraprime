# Base de Dados PostgreSQL (Neon)
# Obtém a connection string em: https://console.neon.tech — Project → Connection Details
DATABASE_URL="postgresql://UTILIZADOR:PASSWORD@HOST/NOME_BASE_DADOS?sslmode=require"

# Porta do servidor Express
PORT=3001

# Ambiente (development | production)
NODE_ENV=development

# URL do frontend (para CORS e redirect do Stripe)
CLIENT_URL=http://localhost:5173

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Obtém estas chaves em: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_SUBSTITUA_PELA_SUA_CHAVE_SECRETA

# Segredo do webhook (obtido em: https://dashboard.stripe.com/webhooks)
STRIPE_WEBHOOK_SECRET=whsec_SUBSTITUA_PELO_SEU_WEBHOOK_SECRET

# Valor da consulta em cêntimos (ex: 5000 = 50,00 €)
STRIPE_BOOKING_FEE_CENTS=5000

# Moeda (ex: eur, usd)
STRIPE_BOOKING_CURRENCY=eur

# ID do preço Stripe (gerado por: node scripts/create-stripe-product.js)
# Cria o produto UMA VEZ e cola aqui o price_XXXX gerado
STRIPE_PRICE_ID=price_XXXX_GERADO_PELO_SETUP_SCRIPT
