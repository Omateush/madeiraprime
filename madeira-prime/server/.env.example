# Base de Dados PostgreSQL (Neon)
# Obtém a connection string em: https://console.neon.tech — Project → Connection Details
DATABASE_URL="postgresql://UTILIZADOR:PASSWORD@HOST/NOME_BASE_DADOS?sslmode=require"

# Porta do servidor Express
PORT=3001

# Ambiente (development | production)
NODE_ENV=development

# URL do frontend (para CORS e redirect do Stripe)
# Actualiza para http://localhost:3000 ao usar o frontend Next.js
CLIENT_URL=http://localhost:3000

# Origens CORS permitidas (separadas por vírgula) — define em produção (ex: Render)
# Se omitido, o servidor usa as origens por defeito (madeiraprime.pt + localhost:3000)
# ALLOWED_ORIGINS=https://madeiraprime.pt,https://www.madeiraprime.pt,https://madeiraprime.vercel.app

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Obtém estas chaves em: https://dashboard.stripe.com/apikeys
# Usa sk_live_... para produção ou sk_test_... para desenvolvimento
STRIPE_SECRET_KEY=sk_live_SUBSTITUA_PELA_SUA_CHAVE_SECRETA

# Segredo do webhook (obtido em: https://dashboard.stripe.com/webhooks)
STRIPE_WEBHOOK_SECRET=whsec_SUBSTITUA_PELO_SEU_WEBHOOK_SECRET

# Valor da consulta em cêntimos (ex: 5000 = 50,00 €)
STRIPE_BOOKING_FEE_CENTS=5000

# Moeda (ex: eur, usd)
STRIPE_BOOKING_CURRENCY=eur

# ID do preço Stripe para marcações (price_XXXX — NÃO o produto prod_XXXX)
# Obtém em: Dashboard Stripe → Products → seleciona o produto → copia o Price ID
# Ou cria automaticamente com: node scripts/create-stripe-product.js
STRIPE_PRICE_ID=price_XXXX_SUBSTITUA_PELO_PRICE_ID_DO_PRODUTO
